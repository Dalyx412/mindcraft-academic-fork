# Optional overrides — primary config is settings.js + keys.json.
# Copy to .env only if you need to override defaults without editing settings.js.

# Gateway API key can also live in keys.json as GATEWAY_API_KEY (recommended).
# GATEWAY_API_KEY=your-gateway-key-here

# Chat / embedding models (defaults match settings.js gateway_* fields).
# GATEWAY_MODEL=claude-sonnet-4-6
# GATEWAY_EMBEDDING_MODEL=text-embedding-3-small

# Set to false to use direct-API profiles (profiles/agent_a.json + agent_b.json, e.g. Qwen).
# USE_GATEWAY=false

# Speech-to-text for VoiceWeb / VoiceAudio (default: qwen when QWEN_API_KEY is set).
# VOICE_STT_PROVIDER=qwen
# QWEN_STT_MODEL=qwen3-asr-flash
# QWEN_API_KEY=...  (prefer keys.json)
